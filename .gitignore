# =========================
# OS files
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

build/
dist/
*.egg-info/

# =========================
# Environment / secrets
# =========================
.env
.env.*
!.env.example

*.key
*.pem
*.p12
*.pfx
secrets.yml
secrets.yaml

# =========================
# Jupyter / notebooks
# =========================
.ipynb_checkpoints/

# =========================
# Quarto / generated files
# =========================
.quarto/
*_cache/
*_files/

# =========================
# VSCode
# Keep shared project settings, ignore personal workspace files
# =========================
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/settings.json

*.code-workspace

# =========================
# Logs / temporary files
# =========================
*.log
*.tmp
*.bak
*.swp

# =========================
# Generated audit outputs
# =========================
**/output/
**/outputs/
**/generated/
**/rendered/
**/.quarto/
**/*_cache/
**/*_files/
**/*.quarto_ipynb

# =========================
# Real audit data / evidence
# Prevent accidental commits of confidential audit files
# =========================
**/04_evidence/01_regulations/*
**/04_evidence/02_raw_data/*
**/04_evidence/03_correspondence/*
**/04_evidence/04_reference_materials/*
**/04_evidence/05_screenshots/*
**/04_evidence/99_generated/*
**/09_archive/*

# Keep folder structure
!**/.gitkeep
!**/04_evidence/README.md
!**/04_evidence/evidence_manifest.yml
!**/04_evidence/02_raw_data/scripts/
!**/04_evidence/02_raw_data/scripts/**

# =========================
# Allow synthetic example data in public repo
# =========================
!examples/**

# Secrets and AI history remain private even inside synthetic examples.
**/.env
**/.env.*
!**/.env.example
**/*.key
**/*.pem
**/*.p12
**/*.pfx
**/secrets.yml
**/secrets.yaml
**/ai_outputs/

/.quarto/
