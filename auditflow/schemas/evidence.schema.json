{
  "title": "AuditFlow Evidence Register",
  "description": "Evidence references used in the audit engagement.",
  "type": "object",
  "required": ["evidence"],
  "additionalProperties": true,
  "properties": {
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "file", "linked_to"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^E-[0-9]{3,}$",
            "examples": ["E-001"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "description": "Relative path to the evidence file.",
            "examples": ["04_evidence/02_raw_data/purchase_orders.xlsx"]
          },
          "linked_to": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "description": "ID of related object such as DS-001, T-001, O-001."
            }
          },
          "notes": {
            "type": "string"
          },
          "received_from": {
            "type": "string"
          },
          "confidentiality": {
            "type": "string",
            "description": "Optional confidentiality classification.",
            "examples": ["public", "internal", "confidential", "restricted"]
          },
          "hash": {
            "type": "string",
            "description": "Optional generated hash. Should normally be generated automatically, not manually maintained."
          }
        }
      }
    }
  }
}