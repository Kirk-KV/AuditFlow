{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditFlow Audit Program",
  "description": "Generated audit program matrix linked to planning decisions and workpapers.",
  "type": "object",
  "required": ["program", "program_rows"],
  "additionalProperties": true,
  "properties": {
    "program": {
      "type": "object",
      "required": ["status", "source"],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1,
          "examples": ["draft"]
        },
        "source": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "planning_decision": {
              "type": "string",
              "minLength": 1,
              "examples": ["01_planning/planning_decision.yml"]
            }
          }
        },
        "note": {
          "type": "string"
        }
      }
    },
    "program_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_id", "risk_id", "risk_title", "workpaper_ref"],
        "additionalProperties": true,
        "properties": {
          "test_id": {
            "type": "string",
            "pattern": "^T-[0-9]{3,}$",
            "examples": ["T-001"]
          },
          "risk_id": {
            "type": "string",
            "pattern": "^R-[0-9]{3,}$",
            "examples": ["R-001"]
          },
          "risk_title": {
            "type": "string",
            "minLength": 1
          },
          "risk_reasoning": {
            "type": "string"
          },
          "control_id": {
            "type": ["string", "null"],
            "pattern": "^C-[0-9]{3,}$",
            "examples": ["C-001"]
          },
          "control_description": {
            "type": "string"
          },
          "control_owner": {
            "type": "string"
          },
          "design_assessment": {
            "type": "string"
          },
          "planning_approach": {
            "type": "string"
          },
          "test_hypothesis": {
            "type": "string"
          },
          "test_script": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "workpaper_ref": {
            "type": "string",
            "pattern": "^WP-[A-Za-z0-9_-]+$",
            "examples": ["WP-C-001"]
          }
        }
      }
    },
    "planning_warnings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "included_risks_without_valid_controls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "risk_id": {
                "type": "string",
                "pattern": "^R-[0-9]{3,}$"
              },
              "risk_title": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
