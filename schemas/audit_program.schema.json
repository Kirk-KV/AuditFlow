{
  "title": "AuditFlow Audit Program",
  "description": "Audit procedures linked to risks, controls, data sources, scripts, and outputs.",
  "type": "object",
  "required": ["tests"],
  "additionalProperties": true,
  "properties": {
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "risk_id", "title", "objective", "procedure"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^T-[0-9]{3,}$",
            "examples": ["T-001"]
          },
          "risk_id": {
            "type": "string",
            "pattern": "^R-[0-9]{3,}$",
            "examples": ["R-001"]
          },
          "control_id": {
            "type": "string",
            "pattern": "^C-[0-9]{3,}$",
            "examples": ["C-001"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "assigned_to": {
            "type": "string"
          },
          "procedure": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "data_sources": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^DS-[0-9]{3,}$"
            }
          },
          "script": {
            "type": "string",
            "description": "Path to the script used to perform the test.",
            "examples": ["04_evidence/02_raw_data/scripts/T001_po_approval_before_release.py"]
          },
          "expected_output": {
            "type": "string",
            "description": "Expected generated output path.",
            "examples": ["04_evidence/99_generated/po_approval_exceptions.xlsx"]
          },
          "expected_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}