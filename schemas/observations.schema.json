{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditFlow Observation",
  "description": "Single generated OBS-XXX.yml observation file.",
  "type": "object",
  "required": [
    "observation_id",
    "status",
    "source_workpaper",
    "source_file",
    "test_id",
    "risk_id",
    "risk_title",
    "title",
    "condition",
    "criteria",
    "cause",
    "risk_effect",
    "recommendation",
    "management_action_plan"
  ],
  "additionalProperties": true,
  "properties": {
    "observation_id": {
      "type": "string",
      "pattern": "^OBS-[0-9]{3,}$",
      "examples": ["OBS-001"]
    },
    "status": {
      "type": "string",
      "examples": ["draft", "validated", "closed"]
    },
    "source_workpaper": {
      "type": "string",
      "pattern": "^WP-[A-Za-z0-9_-]+$",
      "examples": ["WP-C-001"]
    },
    "source_file": {
      "type": "string",
      "examples": ["05_workpapers/WP-C-001.qmd"]
    },
    "test_id": {
      "type": "string",
      "pattern": "^T-[0-9]{3,}$",
      "examples": ["T-001"]
    },
    "risk_id": {
      "type": "string",
      "pattern": "^R-[0-9]{3,}$",
      "examples": ["R-001"]
    },
    "risk_title": {
      "type": "string"
    },
    "control_id": {
      "type": ["string", "null"],
      "pattern": "^C-[0-9]{3,}$",
      "examples": ["C-001"]
    },
    "control_description": {
      "type": "string"
    },
    "control_owner": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "description": "Observation severity according to the company's own scale.",
      "examples": ["High", "Medium", "Low"]
    },
    "condition": {
      "type": "string",
      "description": "What actually happened."
    },
    "criteria": {
      "type": "string",
      "description": "What should happen."
    },
    "cause": {
      "type": "string",
      "description": "Why the issue occurred."
    },
    "risk_effect": {
      "type": "string",
      "description": "What may happen if the issue continues."
    },
    "recommendation": {
      "type": "string"
    },
    "executive_summary": {
      "type": "string"
    },
    "management_action_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "action", "responsible_name", "due_date"],
        "additionalProperties": true,
        "properties": {
          "action_id": {
            "type": "string",
            "pattern": "^MAP-[0-9]{3,}$",
            "examples": ["MAP-001"]
          },
          "action": {
            "type": "string"
          },
          "responsible_name": {
            "type": "string"
          },
          "due_date": {
            "type": "string"
          }
        }
      }
    }
  }
}
